# Auth0 — from your Auth0 app's Settings page (manage.auth0.com)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Generate with: openssl rand -hex 32
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB_NAME=closet_app

# Gemini — centralized here for Leanne's auto-tagging / shopping-suggestions calls
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ElevenLabs — Fairy Godmother voice narration
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Photo upload — pick one, uncomment and fill in
# Vercel Blob
# BLOB_READ_WRITE_TOKEN=
# Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
